# Solicita ao usuário uma palavra e converte ela em minúscula
palavra = input("Digite uma palavra: ").lower()

# Define as vogais e inicializa o contador
vogais = "aeiou"
contador = 0

# Percorre cada letra da palavra e verifica se é vogal ou não
for letra in palavra:
    if letra in vogais:              
        contador += 1                # Se a letra for vogal, adiciona + 1 ao contador

# Exibe o total de vogais
print(f"Quantidade de vogais: {contador}")
