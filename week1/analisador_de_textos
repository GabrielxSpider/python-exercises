# Solicita o nome completo ao usuário
nome = input("Digite seu nome completo: ")

# Separa o nome em partes e pega apenas o primeiro nome
primeiro_nome = nome.split()[0]

# Calcula a quantidade de letras do primeiro nome
quantidade = len(primeiro_nome)

# Exibe o nome em letras maiúsculas
print(nome.upper())

# Exibe o nome em letras minúsculas
print(nome.lower())

# Exibe a quantidade total de letras (sem contar espaços)
print(len(nome.replace(" ", "")))

# Exibe a quantidade de letras do primeiro nome
print(quantidade)